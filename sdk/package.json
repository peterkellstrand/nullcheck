{
  "name": "@nullcheck/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for nullcheck — DeFi token risk analysis across Ethereum, Base, and Solana",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
